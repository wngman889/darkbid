@page "/auth"
@using BlazorDarkBid.Models
@using System.Text
@using System.Text.Json
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http

<h3>User Authentication</h3>

<!-- Tab headers -->
<ul class="nav nav-tabs">
    <li class="nav-item">
        <a class="nav-link @(activeTab == "login" ? "active" : "")" @onclick="@(() => SwitchTab("login"))">Login</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "register" ? "active" : "")" @onclick="@(() => SwitchTab("register"))">Register</a>
    </li>
</ul>

<!-- Tab contents -->
<div class="tab-content mt-3">
    @if (activeTab == "login")
    {
        <div class="tab-pane fade show active">
            <EditForm Model="userDto" OnValidSubmit="HandleLogin">
                <div class="mb-3">
                    <InputText class="form-control" @bind-Value="userDto.Username" placeholder="Username" />
                </div>
                <div class="mb-3">
                    <InputText class="form-control" @bind-Value="userDto.Password" placeholder="Password" type="password" />
                </div>
                <button class="btn btn-primary" type="submit">Login</button>
            </EditForm>
        </div>
    }
    else if (activeTab == "register")
    {
        <div class="tab-pane fade show active">
            <EditForm Model="userDto" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <InputText class="form-control" @bind-Value="userDto.Username" placeholder="Username" />
                </div>
                <div class="mb-3">
                    <InputText class="form-control" @bind-Value="userDto.Email" placeholder="Email" type="email" />
                </div>
                <div class="mb-3">
                    <InputText class="form-control" @bind-Value="userDto.Password" placeholder="Password" type="password" />
                </div>
                <button class="btn btn-success" type="submit">Register</button>
            </EditForm>

        </div>
    }
</div>

@code {
    private string activeTab = "login";

    // Use the Swagger DTO directly
    private User userDto = new();

    private void SwitchTab(string tab)
    {
        activeTab = tab;
    }

    private async Task HandleLogin()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<User>($"https://localhost:7091/api/User/login?username={userDto.Username}&password={userDto.Password}");
            await JS.InvokeVoidAsync("localStorage.setItem", "userId", response.ToString());
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Console.WriteLine("Exception during login: " + ex.Message);
        }
    }

    private async Task HandleRegister()
    {
        try
        {
            // Send POST request with userDto in the body
            var response = await Http.PostAsJsonAsync($"https://localhost:7091/api/User/register?username={userDto.Username}&email={userDto.Email}&password={userDto.Password}", userDto);

            if (response.IsSuccessStatusCode)
            {
                // Store userId in localStorage
                await JS.InvokeVoidAsync("localStorage.setItem", "userId", response.ToString());

                // Navigate to home
                Nav.NavigateTo("/");
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                // Optionally display the error message to the user
                Console.WriteLine("Registration failed: " + errorMessage);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Exception during registration: " + ex.Message);
            // Optionally show a user-friendly error in UI
        }

    }
}

