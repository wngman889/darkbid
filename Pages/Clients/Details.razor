@page "/Auctions/Details/{ProductId:int}"
@using BlazorDarkBid.Models
@inject HttpClient Http

<h2 class="text-center mt-4">Auction Details</h2>

@if (auction == null && errorMessage == null)
{
    <p><em>Loading item...</em></p>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (auction != null)
{
    <div class="details-card">
        @if (!string.IsNullOrWhiteSpace(auction.ImageUrl))
        {
            <img src="@($"https://localhost:7091/{auction.ImageUrl}")" alt="Product Image" class="details-image" />
        }

        <div class="details-content">
            <h3>@(revealedFull? auction.ProductName: "Mystery Item")</h3>

            <p>
                <strong>Brand:</strong>
                <span class="@((revealedBrand && !revealedFull) ? "highlight" : "")">
                    @(revealedBrand? auction.Brand: "???")
                </span>
            </p>
            <p><strong>Category:</strong> @(revealedFull? auction.Category: "???")</p>
            <p><strong>Price:</strong> @(revealedFull ? $"${auction.Price}" : "???")</p>
            <p><strong>Rating:</strong> @(revealedFull? auction.Rating.ToString() : "???")</p>
            <p><strong>Color:</strong> @(revealedFull? auction.Color: "???")</p>
            <p><strong>Size:</strong> @(revealedFull? auction.Size: "???")</p>
            <p><strong>User ID:</strong> @(revealedFull? auction.UserId.ToString() : "???")</p>

            <p class="mt-3"><strong>Time remaining:</strong> @secondsLeft seconds</p>
        </div>
    </div>
}

@code {
    [Parameter] public int ProductId { get; set; }

    private Auction? auction;
    private string? errorMessage;
    private int secondsLeft = 60;
    private bool revealedBrand = false;
    private bool revealedFull = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            auction = await Http.GetFromJsonAsync<Auction>($"https://localhost:7091/api/Auction/get-auction/?id={ProductId}");
            _ = StartTimerAsync(); // Start timer
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load auction: " + ex.Message;
        }
    }

    private async Task StartTimerAsync()
    {
        while (secondsLeft > 0)
        {
            await Task.Delay(1000);
            secondsLeft--;

            if (secondsLeft == 30)
            {
                revealedBrand = true;
            }

            if (secondsLeft == 0)
            {
                revealedFull = true;
            }

            await InvokeAsync(StateHasChanged);
        }
    }
}

